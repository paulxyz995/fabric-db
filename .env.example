# Salin file ini jadi .env lalu ganti nilainya:  cp .env.example .env
# Dipakai oleh docker-compose.yml

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti_password_kuat
POSTGRES_DB=fabricdb

# Keamanan login (WAJIB diganti string acak panjang)
# Buat cepat: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_string_acak_yang_panjang
JWT_EXPIRES_IN=8h

# Port web yang diakses browser (http://IP:PORT)
WEB_PORT=8080
